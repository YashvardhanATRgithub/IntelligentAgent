# LLM Provider: "groq", "cerebras", or "ollama"
LLM_PROVIDER=cerebras

# Groq API Configuration (required if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Cerebras API Configuration (required if LLM_PROVIDER=cerebras)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama-3.3-70b

# Ollama Configuration (required if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Simulation Settings
SIMULATION_SPEED=5.0
NUM_AGENTS=8
